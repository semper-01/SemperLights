# =============================================================================
# Semper Lights — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# For Azure Container Apps, these variables are set in the Container App
# environment variables section, not in a .env file.
#
# WARNING: Never commit the actual .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Settings
# ---------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,*.azurecontainerapps.io
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://yourdomain.com,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://yourdomain.com,https://yourdomain.com

# ---------------------------------------------------------------------------
# Azure Container Apps domain (set after deployment)
# ---------------------------------------------------------------------------
#AZURE_APP_DOMAIN=your-app-name.azurecontainerapps.io

# ---------------------------------------------------------------------------
# Database (Azure Database for PostgreSQL Flexible Server)
# ---------------------------------------------------------------------------
# Preferred: use DATABASE_URL with full connection string
DATABASE_URL=postgres://postgres:your-password@your-server.postgres.database.azure.com:5432/semperlights
# Individual DB_* variables (fallback if DATABASE_URL not set)
DB_NAME=semperlights
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=your-server.postgres.database.azure.com
DB_PORT=5432

# Azure PostgreSQL SSL requirement
PGSSLMODE=require

# ---------------------------------------------------------------------------
# JWT Settings
# ---------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1
JWT_SIGNING_KEY=your-jwt-signing-key

# ---------------------------------------------------------------------------
# Email (Optional — for password reset, notifications)
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@semperlights.com

# ---------------------------------------------------------------------------
# Azure Storage (for persistent volumes in Azure Container Apps)
# ---------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=your-storage-account-name
AZURE_STORAGE_KEY=your-storage-account-key

# ---------------------------------------------------------------------------
# Frontend (compiled into the React build at build time)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=Semper Lights

# ---------------------------------------------------------------------------
# Security (set to True when HTTPS is configured)
# ---------------------------------------------------------------------------
SECURE_SSL_REDIRECT=True